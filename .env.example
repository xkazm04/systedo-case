# --- Web / kanonická URL ----------------------------------------------------
# Kanonický původ webu pro OG tagy, canonical odkazy a sdílecí URL (ShareBar).
# Volitelné: na Vercelu se odvodí automaticky, jinak se použije výchozí doména.
NEXT_PUBLIC_SITE_URL=

# --- LLM (AI asistent + vyhodnocení kampaní) --------------------------------
# Aplikace používá jeden LLM wrapper (src/lib/llm), který přepíná podle prostředí:
#   • development (npm run dev) → Claude Code CLI (model „sonnet", subscription).
#       Stačí mít lokálně nainstalované a přihlášené Claude Code (`claude`).
#       Žádný klíč do .env není potřeba — využívá se měsíční předplatné.
#   • production                → Google Gemini API (klíč níže).
#
# Gemini API klíč (pro produkci). Zdarma v Google AI Studiu:
# https://aistudio.google.com/apikey
# Bez dostupného providera (v devu chybí Claude CLI, v produkci klíč) běží
# nástroje v ukázkovém (demo) režimu — aplikace je funkční i tak.
GEMINI_API_KEY=

# --- Ochrana AI endpointů (rate limiting) -----------------------------------
# Veřejné AI routy (/api/ai, /api/campaigns/analyze) volají placeného providera
# a jsou bez přihlášení. Chrání je per-IP rate limit (src/lib/ai/rate-limit.ts).
# Všechny proměnné jsou volitelné — níže jsou výchozí hodnoty.
# AI_RATE_PER_MIN=8          # generování za minutu na IP
# AI_RATE_PER_DAY=80         # generování za den na IP (rozpočtový strop)
# SYNC_RATE_PER_MIN=20       # synchronizace kampaní za minutu na IP
# AI_MAX_CONCURRENT=4        # max. souběžných volání providera v procesu
# AI_MAX_BODY_BYTES=16384    # max. velikost těla požadavku

# --- Kampaně / Google Ads (bonus, lokální dev režim) ------------------------
# Přehled kampaní (/kampane) běží defaultně na realistických UKÁZKOVÝCH datech.
# Pro napojení na reálný Google Ads API doplňte všechny proměnné níže; konektor
# (src/lib/campaigns/connector.ts) je pak začne používat. Reálné volání API je
# připravený seam — viz googleAdsProvider.fetchCampaigns().
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
