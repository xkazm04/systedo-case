# --- Web / kanonická URL ----------------------------------------------------
# Kanonický původ webu pro OG tagy, canonical odkazy a sdílecí URL (ShareBar).
# Volitelné: na Vercelu se odvodí automaticky, jinak se použije výchozí doména.
NEXT_PUBLIC_SITE_URL=

# --- LLM (AI asistent + vyhodnocení kampaní) --------------------------------
# Aplikace používá jeden LLM wrapper (src/lib/llm), který přepíná podle prostředí:
#   • development (npm run dev) → Claude Code CLI (model „sonnet", subscription).
#       Stačí mít lokálně nainstalované a přihlášené Claude Code (`claude`).
#       Žádný klíč do .env není potřeba — využívá se měsíční předplatné.
#   • production                → Google Gemini API (klíč níže).
#
# Gemini API klíč (pro produkci). Zdarma v Google AI Studiu:
# https://aistudio.google.com/apikey
# Bez dostupného providera (v devu chybí Claude CLI, v produkci klíč) běží
# nástroje v ukázkovém (demo) režimu — aplikace je funkční i tak.
GEMINI_API_KEY=

# --- Ochrana AI endpointů (rate limiting) -----------------------------------
# Veřejné AI routy (/api/ai, /api/campaigns/analyze) volají placeného providera
# a jsou bez přihlášení. Chrání je per-IP rate limit (src/lib/ai/rate-limit.ts).
# Všechny proměnné jsou volitelné — níže jsou výchozí hodnoty.
# AI_RATE_PER_MIN=8          # generování za minutu na IP
# AI_RATE_PER_DAY=80         # generování za den na IP (rozpočtový strop)
# SYNC_RATE_PER_MIN=20       # synchronizace kampaní za minutu na IP
# AI_MAX_CONCURRENT=4        # max. souběžných volání providera v procesu
# AI_MAX_BODY_BYTES=16384    # max. velikost těla požadavku

# --- Auth.js (přihlášení přes Google) ---------------------------------------
# Multi-user cloud režim: uživatelé se přihlašují Google účtem (Auth.js v5),
# session + tokeny se ukládají do Firestore. Viz SETUP.md.
# Tajný klíč pro podpis session: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
AUTH_SECRET=
# Důvěřuj hostiteli z requestu (callback URL na libovolném portu / za proxy).
AUTH_TRUST_HOST=true

# --- Lokální vývoj: bypass přihlášení (DEV) ---------------------------------
# DEV_AUTH=true přeskočí přihlášení přes Google a přihlásí napevno testovacího
# uživatele, takže lze pracovat s aplikací (/app) bez nastaveného OAuthu.
# Bezpečnostní pojistka: IGNORUJE SE, když NODE_ENV=production (v produkci nikdy
# nebypassuje přihlášení). Patří do .env.local (gitignored).
# DEV_AUTH=true
# Volitelné přepsání identity testovacího uživatele (jinak dev-user / Dev Tester):
# DEV_AUTH_USER_ID=dev-user
# DEV_AUTH_USER_NAME=Dev Tester
# DEV_AUTH_USER_EMAIL=dev@local.test

# --- Lokální vývoj: lokální DB místo Firestore (DEV) ------------------------
# LOCAL_DB=true ukládá uživatele + projekty do lokálního node:sqlite souboru
# (.data/systedo.db) místo Firestore, takže lokální vývoj nepotřebuje žádné
# Firebase přihlašovací údaje. Spolu s DEV_AUTH=true je /app plně offline.
# Bezpečnostní pojistka: IGNORUJE SE, když NODE_ENV=production.
#   npm run seed:local     # založí dev uživatele + ukázkové projekty (/app/demo-eshop)
#   npm run dev:local      # = DEV_AUTH=true LOCAL_DB=true next dev
# LOCAL_DB=true

# --- Google OAuth client ----------------------------------------------------
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# (typ "Web application"). Authorized redirect URI:
#   http://localhost:3001/api/auth/callback/google   (+ produkční URL)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Firebase Admin (Firestore) ---------------------------------------------
# Lokálně se použije service-account klíč z .data/firebase-sa.json (vytvořený
# přes gcloud). V produkci místo souboru nastavte celý JSON klíče:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
GOOGLE_CLOUD_PROJECT=

# --- Plánovaná synchronizace + upozornění (cron + e-mail) -------------------
# /api/cron/sync re-synchronizuje připojené uživatele a pošle e-mail při nových
# kritických kampaních. Schedule je ve vercel.json (hodinově). Chráněno tajemstvím
# (Vercel Cron ho posílá jako Bearer token, když je nastavené):
CRON_SECRET=
# E-mail přes Resend (https://resend.com). Bez klíče se upozornění jen logují.
RESEND_API_KEY=
# ALERT_FROM_EMAIL="Systedo <alerts@vase-domena.cz>"
# Volitelný odchozí webhook pro upozornění + týdenní souhrn (Slack/Teams/Discord
# „incoming webhook" — přijímají payload {text}). Bez něj se webhook přeskočí.
# /api/cron/digest posílá týdenní souhrn (schedule ve vercel.json, po 7:00).
# ALERT_WEBHOOK_URL=

# --- Creative Studio (generování vizuálů) -----------------------------------
# Leonardo AI (Lucid Origin) generuje obrázky, Gemini vision je hodnotí a vybírá
# nejlepší z více kandidátů. Bez klíče běží studio v ukázkovém režimu (placeholdery).
# Klíč z app.leonardo.ai:
LEONARDO_API_KEY=
# Model pro hodnocení obrázků (vision) — výchozí je společný GEMINI_MODEL
# (gemini-3-flash-preview, multimodální). Přepiš jen pro jiný vision model.
# GEMINI_VISION_MODEL=
# Embeddingy pro RAG knihovny vzorů (musí být embedding model, ne chat).
# GEMINI_EMBED_MODEL=gemini-embedding-001
# Firebase Storage bucket pro knihovnu vygenerovaných assetů (persistence base64
# + textových promptů). Výchozí v kódu: <GOOGLE_CLOUD_PROJECT>.appspot.com
# FIREBASE_STORAGE_BUCKET=

# --- Google Ads API (živá synchronizace kampaní) ----------------------------
# /kampane běží defaultně na UKÁZKOVÝCH datech. Pro živá data je potřeba
# developer token z Google Ads MANAGER účtu (Tools → API Center) — bez něj
# zůstává živá synchronizace vypnutá a používají se ukázková data. Konektor
# volá Ads API jménem přihlášeného uživatele (jeho OAuth token + vybraný účet).
GOOGLE_ADS_DEVELOPER_TOKEN=
# Manager (MCC) customer id (jen číslice), pokud účty spadají pod MCC.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
