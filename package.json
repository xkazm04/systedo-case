{
  "name": "systedo-case",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "dev": "next dev",
    "dev:local": "cross-env DEV_AUTH=true LOCAL_DB=true next dev",
    "dev:inspect": "cross-env DEV_INSPECT=1 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run build",
    "check:ci": "npm run check && npm run seed:check && npm run test:unit && npm run llm:gate:check",
    "doctor": "node scripts/doctor.mjs",
    "seed": "node scripts/generate-data.mjs",
    "seed:check": "node scripts/generate-data.mjs --check",
    "seed:local": "node scripts/seed-local-db.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --conditions react-server --import ./test-llm/setup.mjs --test \"test-unit/**/*.test.mjs\"",
    "test:llm": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --conditions react-server --import ./test-llm/setup.mjs --test test-llm/real.test.mjs",
    "test:llm:coverage": "node --test test-llm/coverage.test.mjs",
    "llm:gate": "node scripts/llm-gate.mjs",
    "llm:gate:check": "node scripts/llm-gate.mjs --check",
    "llm:list": "node scripts/llm-gate.mjs --list",
    "llm:eval": "node scripts/llm-eval.mjs",
    "llm:eval:update": "node scripts/llm-eval.mjs --update",
    "llm:new": "node scripts/llm-new-tool.mjs",
    "llm:quality": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --conditions react-server --import ./test-llm/setup.mjs test-llm/quality/run.mjs",
    "llm:quality:rejudge": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --conditions react-server --import ./test-llm/setup.mjs test-llm/quality/rejudge.mjs",
    "llm:quality:bake": "node scripts/bake-quality-scores.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth/firebase-adapter": "^2.11.2",
    "@google/genai": "^2.11.0",
    "@types/leaflet": "^1.9.21",
    "firebase-admin": "^13.10.0",
    "framer-motion": "^12.42.2",
    "leaflet": "^1.9.4",
    "next": "16.3.0-preview.5",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.13.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.3.0-preview.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "postcss": "^8.5.10",
    "protobufjs": "^7.6.3",
    "next-auth": {
      "next": "$next"
    }
  }
}
